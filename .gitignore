# ==========================================
# 1. ИГНОРИРОВАТЬ ВСЁ ПО УМОЛЧАНИЮ
# ==========================================
*

# ==========================================
# 2. РАЗРЕШИТЬ НУЖНЫЕ ПАПКИ
# ==========================================
!new_version/
!new_version/**

!templates/
!templates/**

!cpp_files/
!cpp_files/**

!readme.md

# Всегда разрешаем сам файл gitignore
!.gitignore

# ==========================================
# 3. ИГНОРИРОВАТЬ МУСОР ВНУТРИ РАЗРЕШЕННЫХ ПАПОК
# ==========================================

# Игнорируем __pycache__ везде внутри new_version
new_version/**/__pycache__/
new_version/**/*.pyc
new_version/**/*.pyo

# Игнорируем виртуальное окружение
new_version/.venv/
new_version/**/.venv/

# Игнорируем папку logs внутри new_version
new_version/logs/*

# Создайте пустой файл .gitkeep в папке logs и добавьте его в исключения:
!new_version/logs/.gitkeep

# Игнорируем настройки VS Code и OS
.vscode/
.DS_Store
Thumbs.db
*.code-workspace